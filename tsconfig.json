{
  // Standalone config, inspired by @canonical/typescript-config.
  // Base (target/lib/module/strict) mirrors the Canonical config; the rest
  // are library-appropriate additions. Unused-variable/import linting is left
  // to Biome rather than tsc.
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,

    "types": ["node"],

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
