{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["@canonical/biome-config"],
  "files": {
    "includes": ["src", "test", "*.json", "*.ts"]
  },
  "linter": {
    "rules": {
      "suspicious": {
        "noDoubleEquals": {
          "level": "error",
          "options": { "ignoreNull": false }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedGlobals": {
              "level": "error",
              "options": {
                "deniedGlobals": {
                  "self": "Not available on the server; superhref must stay isomorphic.",
                  "navigator": "Not available on the server; superhref must stay isomorphic.",
                  "location": "Not available on the server; superhref must stay isomorphic."
                }
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/**/*.typestest.ts", "src/type-testing/**"],
      "linter": {
        "rules": {
          "correctness": { "noUnusedVariables": "off" }
        }
      }
    }
  ]
}
