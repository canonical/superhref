{
  // Type tests. Kept out of the normal build and check (see the `exclude` in
  // tsconfig.json and tsconfig.build.json) and run on demand via `pnpm typetest`.
  "extends": "./tsconfig.json",
  "compilerOptions": { "noEmit": true },
  "include": ["src/**/*.typestest.ts", "src/type-testing"],
  "exclude": []
}
